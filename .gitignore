# Draft notes live under content/<topic>/_drafts/ and are tracked in git
# (so collaborators can see in-flight work) but excluded from the build
# surface by lib/content.ts and scripts/validate-scholar.mjs. Do not
# gitignore this path — drafts without a commit trail have no
# defensive-publication value.

# Claude Code local state (personal permissions cache)
.claude/settings.local.json

# AI-tooling configuration (Claude Code instructions) — local-only.
# The public technical reference is ARCHITECTURE.md.
CLAUDE.md

# Editorial schedule and campaign cadence — local-only.
# Publishing outcomes are visible on the site; planning details are not.
schedule.md

# generated at build time; CI regenerates from the source of truth
provenance.json
