# Draft notes live flat at content/<topic>/<slug>.mdx with status: draft
# in frontmatter. They are tracked in git so the commit history provides
# defensive prior-art even for unpublished work. Visibility on the site
# is gated by frontmatter status, not by path — see lib/content.ts.

# Claude Code local state (personal permissions cache)
.claude/settings.local.json

# AI-tooling configuration (Claude Code instructions) — local-only.
# The public technical reference is ARCHITECTURE.md.
CLAUDE.md

# Editorial schedule and campaign cadence — local-only.
# Publishing outcomes are visible on the site; planning details are not.
schedule.md

# generated at build time; CI regenerates from the source of truth
provenance.json
